# ── Copy this file to .env.local for local dev ──
# ── Add these same vars in Vercel Dashboard → Settings → Environment Variables ──

# REQUIRED: Admin login password (you choose this)
ADMIN_PASSWORD=YourStrongPassword123!

# REQUIRED: Random secret string (32+ characters)
# Generate one: openssl rand -base64 32
AUTH_SALT=YourRandomSecretString32CharsLong!!

# OPTIONAL: Your site URL (used for absolute URLs)
NEXT_PUBLIC_SITE_URL=https://waterdamageclarksville.com

# OPTIONAL: Lead webhook (Zapier, Make, etc.)
# LEAD_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/...

# OPTIONAL: Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
